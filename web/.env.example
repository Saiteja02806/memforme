# Supabase → Settings → API: Project URL
NEXT_PUBLIC_SUPABASE_URL=

# CRITICAL: Use the anon public key (JWT, role "anon") — NOT the service_role secret.
# The service role belongs only in mcp-server/.env for the MCP process.
# Pasting service_role here causes "Invalid API key" on sign-in / sign-up.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Public MCP server origin (no trailing slash) — shown on Dashboard → Connect AI and /connect.
# Must be NEXT_PUBLIC_* (not MCP_SERVER_URL) so the browser can read it.
# ChatGPT: use your deployed https://… origin (Railway, etc.). Local http://127.0.0.1 only works on your machine.
# Example: https://your-service.up.railway.app
NEXT_PUBLIC_MCP_SERVER_URL=

# Server-only: same value as mcp-server MEMORY_ENCRYPTION_KEY (64 hex or UTF-8 per server rules).
# Used by GET /api/memory-preview to decrypt your own memory_entries rows (never exposed to the browser).
# Do NOT use NEXT_PUBLIC_ for this.
MEMORY_ENCRYPTION_KEY=

# OAuth (MCP connectors: ChatGPT / Claude) — server-only; never expose to the browser.
# Same Supabase project as NEXT_PUBLIC_*; required for /oauth/* and /.well-known/oauth-authorization-server.
SUPABASE_SERVICE_ROLE_KEY=

# Public origin of this Next app (issuer), no trailing slash. Must match what MCP hosts use for discovery.
# Example: https://your-app.vercel.app
OAUTH_ISSUER_URL=

# Optional: access / refresh lifetimes (seconds). Defaults: 86400 / 2592000 (30d).
# OAUTH_ACCESS_TOKEN_TTL_SECONDS=86400
# OAUTH_REFRESH_TOKEN_TTL_SECONDS=2592000
