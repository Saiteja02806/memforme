# Copy to `.env` (gitignored). Never commit real secrets into `.env.example`.

PORT=3000
# Optional: npm run verify:supabase — which auth.users UUID to report on (else first mcp_tokens row / SUPABASE_FALLBACK_USER_ID)
# VERIFY_USER_ID=

# Optional: smoke auto-scans PORT..PORT+14 on 127.0.0.1. Set this for tunnels / remote only:
# SMOKE_BASE_URL=https://your-tunnel.example
# SMOKE_BASE_URL=http://127.0.0.1:3001

# Browser clients (ChatGPT, MCP Inspector) send Origin. Defaults include ChatGPT + common local ports.
# Add tunnel or staging origins (comma-separated, no spaces unless URL-encoded):
# MCP_EXTRA_CORS_ORIGINS=https://your-app.ngrok-free.app,https://your-staging.railway.app
# Allow any http(s)://localhost or 127.0.0.1 with any port (dev only; do not use on public deploy):
# MCP_RELAX_LOCAL_CORS=true

SUPABASE_URL=https://veniblkwjhsovicgkkhf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# 64 hex chars (32 bytes) OR any string (hashed to 32 bytes in dev)
MEMORY_ENCRYPTION_KEY=
# Key rotation only — npm run reencrypt-memories (see docs/DEPLOY_MILESTONE_A.md step 4d)
# OLD_MEMORY_ENCRYPTION_KEY=
# NEW_MEMORY_ENCRYPTION_KEY=

# Auth — pick one:
# A) Insert mcp_tokens row (SHA-256 hex of Bearer secret) — see ../supabase/seed_mcp_token_example.sql
# B) Dev only: BOTH required — plain Bearer secret + valid auth.users UUID (Dashboard → Authentication → Users):
MCP_BEARER_TOKEN=
# Optional: plain secret for npm run inspector-flow / smoke when using Path B only (same as ChatGPT Bearer; must exist in mcp_tokens):
# INSPECTOR_BEARER_TOKEN=
SUPABASE_FALLBACK_USER_ID=
# Or production-style: omit both and use only mcp_tokens (hash via: npm run hash-token -- "secret")
# Production Path B — disable .env Bearer shortcut (only public.mcp_tokens authorizes):
# MCP_DISABLE_ENV_FALLBACK=true

# Request limits (optional)
# MCP_BODY_LIMIT_BYTES=524288
# MCP_RATE_LIMIT_MAX=400
# MCP_RATE_LIMIT_WINDOW=1 minute

# OAuth (MCP hosts the authorization server on the same origin as /mcp).
# MCP_PUBLIC_URL: public https origin of THIS service (no /mcp). On Railway, https://$RAILWAY_PUBLIC_DOMAIN is used if unset.
# Used for /.well-known/oauth-* , /oauth/* , and userinfo `iss` when set.
# MCP_PUBLIC_URL=https://your-mcp.up.railway.app

# Optional: BullMQ markdown resync — see ../docs/REDIS_AND_WORKER.md
# REDIS_URL=redis://127.0.0.1:6379
# START_REDIS_WORKER_IN_PROCESS=true
