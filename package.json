{
  "name": "memforme",
  "private": true,
  "description": "Cross-model memory — run MCP scripts from repo root",
  "scripts": {
    "dev": "npm run dev --prefix mcp-server",
    "build": "npm ci --prefix mcp-server --include=dev && npm run build --prefix mcp-server",
    "start": "npm run start --prefix mcp-server",
    "smoke": "npm run smoke --prefix mcp-server",
    "inspector-flow": "npm run inspector-flow --prefix mcp-server",
    "verify": "npm run verify --prefix mcp-server",
    "hash-token": "node mcp-server/scripts/print-token-hash.mjs",
    "web:dev": "npm run dev --prefix web",
    "web:clean": "npm run clean --prefix web",
    "web:build": "npm run build --prefix web",
    "railway:deploy": "npm run railway:deploy --prefix mcp-server",
    "railway:status": "npm run railway:status --prefix mcp-server",
    "worker": "npm run worker --prefix mcp-server",
    "verify:supabase": "npm run verify:supabase --prefix mcp-server",
    "reencrypt-memories": "npm run reencrypt-memories --prefix mcp-server"
  },
  "devDependencies": {
    "supabase": "^2.88.1"
  }
}
